# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/leveled

# WHOOP credentials
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=https://localhost:3000/auth/whoop/callback
WHOOP_API_HOSTNAME=https://api.prod.whoop.com
WHOOP_WEBHOOK_SECRET=

# Security
# Generate with: npm run keys:generate
TOKEN_ENCRYPTION_KEY=
SESSION_SECRET=

# Server
PORT=3000
NODE_ENV=development

# HTTPS (local dev) — paths relative to backend/, generated via mkcert
TLS_CERT_PATH=certs/localhost.pem
TLS_KEY_PATH=certs/localhost-key.pem
